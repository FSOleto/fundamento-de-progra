#include <iostream>
using namespace std;

int main() {
    long long numero;
    int digito;
    
    int mayor = -1;
    int menor = 9;
    int contadorMax = 0;

    cout << "Ingrese un numero entero positivo: ";
    cin >> numero;

    
    if (numero < 0) {
        cout << "El numero debe ser positivo." << endl;
        return 0;
    }

    if (numero == 0) {
        cout << "Mayor consumo: 0" << endl;
        cout << "Menor consumo: 0" << endl;
        cout << "El valor maximo se repite 1 vez." << endl;
        return 0;
    }

    while (numero > 0) {
        digito = numero % 10;

        if (digito > mayor) {
            mayor = digito;
            contadorMax = 1; 
        } else if (digito == mayor) {
            contadorMax++;
        }

        if (digito < menor) {
            menor = digito;
        }

        numero /= 10;
    }

   
    cout << "Mayor consumo: " << mayor << " GB" << endl;
    cout << "Menor consumo: " << menor << " GB" << endl;
    cout << "El valor maximo se repite " << contadorMax << " veces." << endl;

    return 0;
}
