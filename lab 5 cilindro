
#include <stdio.h>
#include <math.h>

int main()
{
     float r,h;
     float area_lat,volumen;
     const float PI=3.1416;
     
     printf("ingresar el area del cilindro: ");
     scanf("%f",&r);
     
     printf("ingresar la altura del cilindro: ");
     scanf("%f",&h);
     
     area_lat= 2*PI*r*h;
     volumen= PI*pow(r,2)*h;
     
     printf("\n----RESULTADOS----\n");
     printf("Area Lateral: %.2f\n",area_lat);
     printf("volumen: %.2f\n",volumen);

    return 0;
}
